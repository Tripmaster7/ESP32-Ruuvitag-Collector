#include "menu.hpp"
#include "storage.hpp"
#include "WifiBootstrap.hpp"
#include <WiFi.h>
#include "timer.hpp"

namespace menu{
    namespace{
        std::string watchDogWarning="You need to input something every 60 seconds or watchdog resets";
        std::string lineSeparator="------------------------";
        
        void mainMenu(){
            Serial.println();
            Serial.println(F("MAIN MENU"));
            Serial.println(lineSeparator.c_str());
            Serial.println(F("(1) Read SPIFFS files"));
            Serial.println(F("(2) Manage SPIFFS"));
            Serial.println(F("(3) Clear WiFi credentials"));
            Serial.println(F("(9) Exit"));
            Serial.println(lineSeparator.c_str());
            Serial.println(watchDogWarning.c_str());
            Serial.println();
        }

        void subMenu12(){
            Serial.println(lineSeparator.c_str());
            Serial.println(F("(1) List files"));
            Serial.println(F("(2) Print one file,  long  names"));
            Serial.println(F("(3) Print all files, long  names"));
            Serial.println(F("(4) Print one file,  short names"));
            Serial.println(F("(5) Print all files, short names"));
            Serial.println(F("(9) Exit"));
            Serial.println(lineSeparator.c_str());
            Serial.println();
        }
        
        void subMenu1(){
            Serial.println();
            Serial.println(F("Read SPIFFS files"));
            subMenu12();
        }

        void subMenu3(){
            Serial.println();
            Serial.println(F("Manage SPIFFS"));
            Serial.println(lineSeparator.c_str());
            Serial.println(F("(1) List files"));
            Serial.println(F("(2) Delete file"));
            Serial.println(F("(3) Format file system"));
            Serial.println(F("(9) Exit"));
            Serial.println(lineSeparator.c_str());
            Serial.println();
        }

        char inputCharacter(std::string choices){
            std::stringstream stream;

            timer::watchdog::feed();
            
            Serial.print("Choose ");
            std::vector<char> vChoices(choices.begin(), choices.end());
            for(int i=0;i<vChoices.size();i++){
                stream << vChoices[i];
                if(vChoices.size()-i>2){
                    stream << ", ";   
                }
                if(i==vChoices.size()-2){
                    stream << " or ";   
                }
            }
            Serial.print(stream.str().c_str());
            Serial.print(": ");

            while(true){
                if(Serial.available()>0){
                    int character=Serial.read();
                    if(choices.find(toupper((char)character))!= std::string::npos){
                        Serial.println((char)character);
                        return (char)character;
                    }
                }
            }
            return 255;
        }

        std::string inputString(std::string message){
            std::stringstream stream;
            const size_t maxInputLen = 64;
            Serial.print(message.c_str());
            while(true){
                if(Serial.available()>0){
                    int ch=Serial.read();
                    if(ch==10||ch==13){
                        break;
                    }
                    if(stream.str().length() < maxInputLen){
                        stream << (char)ch;
                        Serial.print((char)ch);
                    }
                }
            }
            return stream.str();
        }

        void printOneFile(bool longOrShortColumns,storage::OutputType outputType){
            std::string fileName;
            bool currentColumnNames;
            fileName=inputString("Type file name: ");
            Serial.println();
            Serial.println();
            if(fileName.length()>0){
                if(storage::spif::exists(fileName)){
                    currentColumnNames=config::longColumnNames;
                    config::longColumnNames=longOrShortColumns;
                    storage::spif::read(fileName,outputType);
                    config::longColumnNames=currentColumnNames;
                }else{
                    Serial.println(F("File not found"));
                }
            }
        }

        void deleteFile(){
            std::string fileName;
            fileName=inputString("Type file name: ");
            Serial.println();
            Serial.println();
            if(fileName.length()>0){
                if(storage::spif::exists(fileName)){
                    storage::spif::deleteFile(fileName);
                }else{
                    Serial.println(F("File not found"));
                }
            }
        }

        void printAllFiles(bool longOrShortColumns,storage::OutputType outputType){
            bool currentColumnNames;
            currentColumnNames=config::longColumnNames;
            config::longColumnNames=longOrShortColumns;
            storage::spif::readAllFiles(outputType);
            config::longColumnNames=currentColumnNames;
        }

        void readSelection(char selection){
            switch(selection){
                case '1':
                    storage::spif::list();
                    break;
                case '2':
                    printOneFile(true,storage::print);
                    break;
                case '3':
                    printAllFiles(true,storage::print);
                    break;
                case '4':
                    printOneFile(false,storage::print);
                    break;
                case '5':
                    printAllFiles(false,storage::print);
                    break;
                case '9':
                default:
                    break;
            }            
        }

        int menuAction(char digit){
            switch(digit){
                case '1':
                    char selection;
                    selection=255;                    
                    while(selection!='9'){
                        subMenu1();
                        selection=inputCharacter("12359");
                        readSelection(selection);
                    }
                    break;
                case '2':
                    selection=255;                    
                    while(selection!='9'){
                        subMenu3();
                        selection=inputCharacter("1239");
                        switch(selection){
                            case '1':
                                storage::spif::list();
                                break;
                            case '2':
                                deleteFile();
                                break;
                            case '3':
                                Serial.println(F("Confirm SPIFFS format?"));
                                selection=inputCharacter("YN");
                                if(selection=='Y'||selection=='y'){
                                    storage::spif::format();
                                }
                                break;
                            case '9':
                            default:
                                break;
                        }
                    }
                    break;
                case '3':
                    Serial.println(F("Clear WiFi credentials?"));
                    selection=inputCharacter("YN");
                    if(selection=='Y'||selection=='y'){
                        wifibootstrap::clearCredentials();
                    }
                    break;
                case '9':
                    return '9';
                    break;      
                default:
                    break;
            }
            mainMenu();
            return digit;
        }

        void _menu(){
            boolean inputReceived=false;
            int menuStart=millis();
            Serial.println(F("Press number key for menu (2s)..."));
            while(Serial.available()==0){
                if(!inputReceived && millis()-menuStart>2000){
                    break;
                }
            }
            int digit=Serial.read();
            if(digit>=48 && digit<=57){
                inputReceived=true;
                mainMenu();
            }
            delay(200);
            Serial.flush();
            while(inputReceived){
                if(menuAction(inputCharacter("1239"))=='9'){
                    break;
                }
            }
        }
    }

    void menu(){
        if(WiFi.isConnected() || global::bootCount<2){
            _menu();
        }
    }
}
